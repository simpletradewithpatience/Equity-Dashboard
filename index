  {name:"ICICIGI",ref:1844,inv_r:1783,up1_r:1905,up2_r:1966,inv_s:1767.75,up1_s:1958.78,up2_s:2044.86,sentiment:"Bullish",trend:"Up",rsi:58.88,rsiLabel:"Healthy",volume:"Normal",volx:0.78,change:2.71,momentum:"Strong",risk:"High",vol_out:"Low"},
  {name:"MFSL",ref:1697,inv_r:1630.17,up1_r:1763.83,up2_r:1830.66,inv_s:1556.66,up1_s:1977.69,up2_s:2188.2,sentiment:"Bullish",trend:"Up",rsi:58.95,rsiLabel:"Healthy",volume:"High Volume",volx:1.75,change:3.46,momentum:"Strong",risk:"High",vol_out:"High"},
  {name:"DEEPAKNTR",ref:1672.4,inv_r:1610.35,up1_r:1734.45,up2_r:1796.5,inv_s:1536.14,up1_s:1944.92,up2_s:2149.32,sentiment:"Neutral",trend:"Range",rsi:46.32,rsiLabel:"Healthy",volume:"High Volume",volx:1.83,change:2.66,momentum:"Strong",risk:"High",vol_out:"High"},
  {name:"ADANIGREEN",ref:1520,inv_r:1462.64,up1_r:1577.36,up2_r:1634.72,inv_s:1448.3,up1_s:1602.6,up2_s:1664.55,sentiment:"Neutral",trend:"Range",rsi:61.59,rsiLabel:"Strong",volume:"Low Volume",volx:0.59,change:2.8,momentum:"Weak",risk:"High",vol_out:"Low"},
  {name:"TORNTPOWER",ref:1459,inv_r:1406.93,up1_r:1511.07,up2_r:1563.14,inv_s:1388.39,up1_s:1600.21,up2_s:1706.12,sentiment:"Bullish",trend:"Up",rsi:48.21,rsiLabel:"Healthy",volume:"Above Avg",volx:1.13,change:2.93,momentum:"Strong",risk:"High",vol_out:"Moderate"},
  {name:"OLECTRA",ref:1454,inv_r:1339.7,up1_r:1568.3,up2_r:1682.6,inv_s:1179.68,up1_s:2002.64,up2_s:2414.12,sentiment:"Bullish",trend:"Up",rsi:68.43,rsiLabel:"Strong",volume:"High Volume",volx:3.74,change:6.77,momentum:"Strong",risk:"High",vol_out:"High"},
  {name:"SYRMA",ref:1352.2,inv_r:1297.97,up1_r:1406.43,up2_r:1460.66,inv_s:1273.33,up1_s:1509.94,up2_s:1628.25,sentiment:"Neutral",trend:"Up",rsi:78.95,rsiLabel:"Overbought / Euphoria",volume:"Above Avg",volx:1.01,change:3.74,momentum:"Moderate",risk:"High",vol_out:"Moderate"},
  {name:"KPRMILL",ref:1208.7,inv_r:1044.61,up1_r:1372.79,up2_r:1536.88,inv_s:736.12,up1_s:2153.86,up2_s:2862.73,sentiment:"Neutral",trend:"Up",rsi:75.38,rsiLabel:"Overbought / Euphoria",volume:"High Volume",volx:15.49,change:13.72,momentum:"Strong",risk:"High",vol_out:"High"},
  {name:"ABSLAMC",ref:1170.1,inv_r:1096.25,up1_r:1243.95,up2_r:1317.8,inv_s:1046.92,up1_s:1416.46,up2_s:1601.24,sentiment:"Bullish",trend:"Up",rsi:64.17,rsiLabel:"Strong",volume:"Above Avg",volx:1.39,change:6.3,momentum:"Strong",risk:"High",vol_out:"Moderate"},
  {name:"FINCABLES",ref:1173,inv_r:1113.93,up1_r:1232.07,up2_r:1291.14,inv_s:1070.93,up1_s:1377.15,up2_s:1530.26,sentiment:"Bullish",trend:"Up",rsi:64.25,rsiLabel:"Strong",volume:"Above Avg",volx:1.44,change:3.45,momentum:"Strong",risk:"High",vol_out:"Moderate"},
  {name:"GODREJIND",ref:1126,inv_r:1041.83,up1_r:1210.17,up2_r:1294.34,inv_s:923.99,up1_s:1530.02,up2_s:1833.03,sentiment:"Neutral",trend:"Range",rsi:58.1,rsiLabel:"Healthy",volume:"High Volume",volx:4.24,change:5.61,momentum:"Strong",risk:"High",vol_out:"High"},
  {name:"MAXHEALTH",ref:1095.6,inv_r:1025.06,up1_r:1166.14,up2_r:1236.68,inv_s:934.77,up1_s:1417.26,up2_s:1658.51,sentiment:"Bullish",trend:"Up",rsi:69.67,rsiLabel:"Strong",volume:"High Volume",volx:1.9,change:6.27,momentum:"Strong",risk:"High",vol_out:"High"}
];

let activeFilter='all';
let openCards=new Set();
function fmt(n){return Number(n).toLocaleString('en-IN',{maximumFractionDigits:2});}
function rsiColor(v){if(v>=70)return'red';if(v>=60)return'amber';return'';}

function renderCards(){
  const q=document.getElementById('searchInput').value.toLowerCase();
  const container=document.getElementById('cardsContainer');
  const filtered=stocks.filter(s=>{
    const matchQ=s.name.toLowerCase().includes(q);
    if(activeFilter==='all')return matchQ;
    if(activeFilter==='Bullish')return matchQ&&s.sentiment==='Bullish';
    if(activeFilter==='Neutral')return matchQ&&s.sentiment==='Neutral';
    if(activeFilter==='Up')return matchQ&&s.trend==='Up';
    if(activeFilter==='Range')return matchQ&&s.trend==='Range';
    if(activeFilter==='Strong')return matchQ&&s.momentum==='Strong';
    return matchQ;
  });
  document.getElementById('count-label').textContent=filtered.length+' stock'+(filtered.length!==1?'s':'')+' shown';
  if(filtered.length===0){container.innerHTML='<div class="no-results">No stocks match your filter.</div>';return;}
  container.innerHTML=filtered.map(s=>{
    const isOpen=openCards.has(s.name);
    const rc=rsiColor(s.rsi);
    const sentBadge=s.sentiment==='Bullish'?'badge-bull':'badge-neut';
    return `<div class="card">
      <div class="card-header">
        <span class="stock-name">${s.name}</span>
        <div class="badges">
          <span class="badge ${sentBadge}">${s.sentiment}</span>
          <span class="badge badge-chg">+${s.change}%</span>
        </div>
      </div>
      <div class="metrics">
        <div class="metric">
          <div class="metric-label">Reference</div>
          <div class="metric-val">₹${fmt(s.ref)}</div>
        </div>
        <div class="metric">
          <div class="metric-label">RSI · ${s.rsi}</div>
          <div class="metric-val">${s.rsiLabel}</div>
          <div class="rsi-bar-wrap"><div class="rsi-bar ${rc}" style="width:${Math.min(s.rsi,100)}%"></div></div>
        </div>
        <div class="metric">
          <div class="metric-label">Trend</div>
          <div class="metric-val">${s.trend}</div>
        </div>
        <div class="metric">
          <div class="metric-label">Momentum</div>
          <div class="metric-val">${s.momentum}</div>
        </div>
      </div>
      <button class="toggle-btn" onclick="toggleCard('${s.name}')">
        <i class="ti ti-${isOpen?'chevron-up':'chevron-down'}"></i>
        ${isOpen?'Hide details':'View full levels'}
      </button>
      <div class="expand-section ${isOpen?'open':''}" id="expand-${s.name}">
        <div class="section-title">Reference setup</div>
        <div class="level-row"><span class="level-label">Invalidation</span><span class="dn-val">₹${fmt(s.inv_r)}</span></div>
        <div class="level-row"><span class="level-label">Upside target 1</span><span class="up-val">₹${fmt(s.up1_r)}</span></div>
        <div class="level-row"><span class="level-label">Upside target 2</span><span class="up-val">₹${fmt(s.up2_r)}</span></div>
        <div class="section-title">Swing setup (2–5 days)</div>
        <div class="level-row"><span class="level-label">Invalidation</span><span class="dn-val">₹${fmt(s.inv_s)}</span></div>
        <div class="level-row"><span class="level-label">Upside target 1</span><span class="up-val">₹${fmt(s.up1_s)}</span></div>
        <div class="level-row"><span class="level-label">Upside target 2</span><span class="up-val">₹${fmt(s.up2_s)}</span></div>
        <div class="section-title">Final outlook</div>
        <div class="outlook-grid">
          <div class="outlook-item">Momentum<div class="outlook-val">${s.momentum}</div></div>
          <div class="outlook-item">Trend<div class="outlook-val">${s.trend}</div></div>
          <div class="outlook-item">Risk<div class="outlook-val">${s.risk}</div></div>
          <div class="outlook-item">Volume<div class="outlook-val">${s.vol_out}</div></div>
        </div>
        <div class="section-title" style="margin-top:10px">Volume info</div>
        <div class="level-row"><span class="level-label">Vol multiplier</span><span>${s.volx}x · ${s.volume}</span></div>
      </div>
    </div>`;
  }).join('');
}

function toggleCard(name){
  if(openCards.has(name))openCards.delete(name);
  else openCards.add(name);
  renderCards();
}

function setFilter(val,el){
  activeFilter=val;
  document.querySelectorAll('.pill').forEach(p=>p.classList.remove('active'));
  el.classList.add('active');
  renderCards();
}

renderCards();
</script>
</body>
</html>
