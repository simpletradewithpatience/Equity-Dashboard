<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>STWP Equity Snapshots</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css">
<style>
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:#f5f5f0;color:#1a1a1a;min-height:100vh}
  .app{max-width:480px;margin:0 auto;background:#fff;min-height:100vh}
  .header{padding:1rem 1rem 0.5rem;border-bottom:0.5px solid #e0e0d8;background:#fff;position:sticky;top:0;z-index:10}
  .title{font-size:18px;font-weight:600;color:#1a1a1a}
  .subtitle{font-size:13px;color:#888;margin-top:2px}
  .filters{display:flex;gap:8px;padding:0.75rem 1rem;flex-wrap:wrap;background:#fff;border-bottom:0.5px solid #e0e0d8;position:sticky;top:62px;z-index:9}
  .pill{font-size:12px;padding:5px 12px;border-radius:20px;border:0.5px solid #ccc;background:#fff;color:#666;cursor:pointer;transition:all 0.15s;white-space:nowrap}
  .pill.active{background:#e8f0fe;color:#1a56db;border-color:#a5b4fc}
  .search{margin:0.75rem 1rem 0;position:relative}
  .search input{width:100%;padding:9px 12px 9px 36px;border-radius:10px;border:0.5px solid #ccc;background:#f7f7f3;color:#1a1a1a;font-size:14px;outline:none}
  .search input:focus{border-color:#a5b4fc;background:#fff}
  .search i{position:absolute;left:11px;top:50%;transform:translateY(-50%);color:#888;font-size:16px}
  .count{font-size:12px;color:#888;padding:0.5rem 1rem 0.25rem}
  .cards{padding:0.5rem 1rem 1rem;display:flex;flex-direction:column;gap:10px}
  .card{background:#fff;border:0.5px solid #e0e0d8;border-radius:14px;padding:1rem;transition:box-shadow 0.15s}
  .card:active{box-shadow:0 2px 12px rgba(0,0,0,0.08)}
  .card-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
  .stock-name{font-size:16px;font-weight:600;color:#1a1a1a}
  .badges{display:flex;gap:6px;align-items:center;flex-wrap:wrap}
  .badge{font-size:11px;padding:3px 9px;border-radius:12px;font-weight:500}
  .badge-bull{background:#d1fae5;color:#065f46}
  .badge-neut{background:#f3f4f6;color:#4b5563}
  .badge-chg{background:#eff6ff;color:#1e40af}
  .metrics{display:grid;grid-template-columns:repeat(2,1fr);gap:8px}
  .metric{background:#f7f7f3;border-radius:8px;padding:8px 10px}
  .metric-label{font-size:11px;color:#888;margin-bottom:2px}
  .metric-val{font-size:13px;font-weight:500;color:#1a1a1a}
  .rsi-bar-wrap{height:3px;border-radius:2px;background:#e5e7eb;margin-top:5px;overflow:hidden}
  .rsi-bar{height:3px;border-radius:2px;background:#10b981;transition:width 0.3s}
  .rsi-bar.amber{background:#f59e0b}
  .rsi-bar.red{background:#ef4444}
  .expand-section{margin-top:10px;padding-top:10px;border-top:0.5px solid #e0e0d8;display:none}
  .expand-section.open{display:block}
  .section-title{font-size:11px;font-weight:600;color:#888;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:6px;margin-top:12px}
  .section-title:first-child{margin-top:0}
  .level-row{display:flex;justify-content:space-between;font-size:13px;padding:5px 0;border-bottom:0.5px solid #f0f0ea;color:#1a1a1a}
  .level-row:last-child{border:none}
  .level-label{color:#888}
  .outlook-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;margin-top:4px}
  .outlook-item{font-size:12px;color:#888;background:#f7f7f3;border-radius:8px;padding:8px 10px}
  .outlook-val{font-weight:600;color:#1a1a1a;font-size:13px;margin-top:2px}
  .toggle-btn{font-size:12px;color:#1a56db;margin-top:10px;background:none;border:none;cursor:pointer;padding:0;display:flex;align-items:center;gap:4px;font-family:inherit}
  .disclaimer{margin:1rem;padding:1rem;background:#fef9ee;border-radius:10px;border:0.5px solid #fcd34d;font-size:11px;color:#78350f;line-height:1.6}
  .disclaimer strong{display:block;margin-bottom:4px;font-size:12px}
  .no-results{text-align:center;padding:3rem 1rem;color:#888;font-size:14px}
  .up-val{color:#059669;font-weight:500}
  .dn-val{color:#dc2626;font-weight:500}
  @media(prefers-color-scheme:dark){
    body{background:#111;color:#f0f0f0}
    .app{background:#1a1a1a}
    .header,.filters{background:#1a1a1a;border-color:#333}
    .card{background:#242424;border-color:#333}
    .metric,.outlook-item{background:#2c2c2c}
    .metric-label,.level-label,.outlook-item,.count,.subtitle{color:#aaa}
    .metric-val,.stock-name,.level-row,.outlook-val,.title{color:#f0f0f0}
    .search input{background:#2c2c2c;border-color:#444;color:#f0f0f0}
    .pill{background:#1a1a1a;color:#aaa;border-color:#444}
    .pill.active{background:#1e2a5a;color:#93c5fd;border-color:#3b5abf}
    .level-row{border-color:#333}
    .rsi-bar-wrap{background:#333}
    .expand-section{border-color:#333}
    .badge-bull{background:#064e3b;color:#6ee7b7}
    .badge-neut{background:#2c2c2c;color:#9ca3af}
    .badge-chg{background:#1e3a5f;color:#93c5fd}
    .disclaimer{background:#2d1f00;border-color:#92400e;color:#fcd34d}
    .section-title{color:#777}
  }
</style>
</head>
<body>
<div class="app">
  <div class="header">
    <div class="title">📊 STWP Equity Snapshots</div>
    <div class="subtitle">Tap any stock to view full levels</div>
  </div>

  <div class="filters">
    <span class="pill active" onclick="setFilter('all',this)">All</span>
    <span class="pill" onclick="setFilter('Bullish',this)">Bullish</span>
    <span class="pill" onclick="setFilter('Neutral',this)">Neutral</span>
    <span class="pill" onclick="setFilter('Up',this)">Trend Up</span>
    <span class="pill" onclick="setFilter('Range',this)">Trend Range</span>
    <span class="pill" onclick="setFilter('Strong',this)">Strong</span>
  </div>

  <div class="search">
    <i class="ti ti-search"></i>
    <input type="text" id="searchInput" placeholder="Search stock…" oninput="renderCards()">
  </div>

  <div class="count" id="count-label"></div>
  <div class="cards" id="cardsContainer"></div>

  <div class="disclaimer">
    <strong>⚠️ Disclaimer</strong>
    This analysis is generated strictly for educational and analytical purposes only. It does NOT constitute investment advice, trading advice, or a recommendation to buy or sell any security or derivative instrument. Options trading involves substantial risk and may not be suitable for all participants. Readers are advised to exercise independent judgment and consult a SEBI-registered financial advisor before taking any trading or investment decisions. STWP assumes no responsibility for any financial loss arising from the use of this analysis.
  </div>
</div>

<script>
