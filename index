  {name:"CPPLUS",ref:3515.6,inv_r:3365.66,up1_r:3665.54,up2_r:3815.48,inv_s:3328.17,up1_s:3808.81,up2_s:4028.72,sentiment:"Neutral",trend:"Range",rsi:75.42,rsiLabel:"Overbought / Euphoria",volume:"Low Volume",volx:0.68,change:4.94,momentum:"Moderate",risk:"High",vol_out:"Low"},
