  {name:"TRENT",ref:3192,inv_r:3097.1,up1_r:3286.9,up2_r:3381.8,inv_s:2964.24,up1_s:3647.52,up2_s:3989.16,sentiment:"Neutral",trend:"Range",rsi:40.82,rsiLabel:"Healthy",volume:"High Volume",volx:3.05,change:2.48,momentum:"Strong",risk:"High",vol_out:"High"},
  {name:"ACUTAAS",ref:3147.6,inv_r:2997.95,up1_r:3297.25,up2_r:3446.9,inv_s:2960.54,up1_s:3432.41,up2_s:3646.02,sentiment:"Neutral",trend:"Range",rsi:58.01,rsiLabel:"Healthy",volume:"Normal",volx:0.79,change:4.55,momentum:"Moderate",risk:"High",vol_out:"Low"},
  {name:"LUPIN",ref:2337.9,inv_r:2277.13,up1_r:2398.67,up2_r:2459.44,inv_s:2264.98,up1_s:2483.75,up2_s:2593.13,sentiment:"Bullish",trend:"Up",rsi:59.04,rsiLabel:"Healthy",volume:"Normal",volx:1,change:2.43,momentum:"Strong",risk:"High",vol_out:"Moderate"},
